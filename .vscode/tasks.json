{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Publish iOS - Archive",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"publish",
				"SilvaData.csproj",
				"-f",
				"net10.0-ios",
				"-c",
				"Release",
				"/p:ArchiveOnBuild=true",
				"/p:RuntimeIdentifier=ios-arm64"
			],
			"problemMatcher": [],
			"group": "build"
		}
	]
}